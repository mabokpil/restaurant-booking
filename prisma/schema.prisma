generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Reservation {
  id        Int      @id @default(autoincrement())
  name      String
  date      String
  time      String
  people    Int
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
